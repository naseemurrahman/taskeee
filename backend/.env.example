# --- Your PC as a production-like server (before cloud) ---
# From repo root:  npm run deps:up     (starts Postgres + Redis only via Docker)
# Match DATABASE_URL to docker-compose.yml postgres service, then:
#   cd backend && npm run migrate && npm start
#   cd frontend && npm run build && npm run preview:prod
# For NODE_ENV=production with local Docker Postgres (no TLS), you MUST set:
#   DATABASE_SSL=false
# Optional: copy this file to backend/.env and set strong JWT_* and MFA_ENCRYPTION_KEY.
#
# DATABASE_URL=postgresql://taskflow:devpassword123@127.0.0.1:5433/taskflow_dev
# (compose maps Postgres to host port 5433 so it does not clash with a local Postgres on 5432)
# DATABASE_SSL=false
# NODE_ENV=production
# CLIENT_ORIGIN=http://localhost:5174
# REDIS_URL=redis://localhost:6379

# --- Cloud / real production ---
# NODE_ENV=production, CLIENT_ORIGIN=https://your-spa-origin
# Omit DATABASE_SSL or set DATABASE_SSL=true so Postgres uses TLS with cert verification.

# PostgreSQL is required for live multi-tenant data (org_id on users, tasks, etc.). Demo mode
# activates only if the DB is unreachable — do not rely on it in production.

DATABASE_URL=postgresql://user:pass@127.0.0.1:5433/taskflow
# Local Docker Postgres on Windows/Mac/Linux: use DATABASE_SSL=false when NODE_ENV=production
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_min_32_chars_long_secret__
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars___
JWT_EXPIRES_IN=15m
PORT=3001
CLIENT_ORIGIN=http://localhost:5174

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com

# MFA (TOTP)
# 32+ bytes, base64 recommended
MFA_ENCRYPTION_KEY=change_me_32_bytes_minimum________________
MFA_ISSUER=TaskFlow Pro

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AWS S3 (evidence storage — optional; omit in demo)
AWS_REGION=us-east-1
S3_BUCKET=

# AI service
AI_SERVICE_URL=http://localhost:8000

# Stripe (subscriptions — org plans / seat limits; webhook must hit your public API URL)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Realtime (Socket.IO — same origin as API or configure CORS in server.js)
# Notifications and task comment pushes expect a running server with Redis for scale-out.
