# ===========================================
# TaskFlow Pro - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!

# --- Server ---
NODE_ENV=development
PORT=3001

# --- Database (PostgreSQL) ---
# Local Docker: postgres://taskflow:devpassword123@127.0.0.1:5433/taskflow_dev
# Production: postgres://user:password@host:5432/taskflow
DATABASE_URL=postgresql://taskflow:devpassword123@127.0.0.1:5433/taskflow_dev
DATABASE_SSL=false

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379

# --- Security (REQUIRED - Generate strong random strings) ---
# Generate secrets: openssl rand -base64 32
JWT_SECRET=change_me_min_32_chars_long_secret__
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars___
JWT_EXPIRES_IN=15m

# MFA Encryption (32+ bytes)
MFA_ENCRYPTION_KEY=change_me_32_bytes_minimum________________
MFA_ISSUER=TaskFlow Pro

# --- CORS ---
# For local development
CLIENT_ORIGIN=http://localhost:5173

# For production, set your domain
# CLIENT_ORIGIN=https://your-domain.com

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com

# --- AWS S3 (optional - for file uploads) ---
AWS_REGION=us-east-1
S3_BUCKET=taskflow-photos
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# --- AI Service (optional) ---
AI_SERVICE_URL=http://localhost:8000

# --- Stripe Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
