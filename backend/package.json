{
  "name": "taskflow-pro-backend",
  "version": "1.0.0",
  "description": "TaskFlow Pro - Hierarchical Task Management API",
  "main": "src/server.js",
  "scripts": {
    "deps:up": "docker compose up -d postgres redis",
    "deps:down": "docker compose stop postgres redis",
    "deps:logs": "docker compose logs -f postgres redis",
    "migrate": "node scripts/migrate.js",
    "deploy": "node scripts/deploy.js",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node -e \"console.log('Backend has no build step')\"",
    "smoke": "node scripts/smoke.js",
    "validate:smoke": "node scripts/validate-smoke.js",
    "test": "jest",
    "db:test": "node scripts/test-db.js",
    "admin:create": "node scripts/create-admin.js",
    "dev:set-password": "node scripts/dev-set-password.js",
    "test:coverage": "jest --coverage",
    "audit:task-assignees": "node scripts/audit-task-assignees.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/s3-request-presigner": "^3.478.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "redis": "^4.7.1",
    "sequelize": "^6.37.8",
    "socket.io": "^4.6.2",
    "stripe": "^22.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
